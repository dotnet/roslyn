<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(NetVSCode)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>roslyn-language-server</AssemblyName>
    <RootNamespace>Microsoft.CodeAnalysis.LanguageServer.Client</RootNamespace>

    <!-- The thin client must stay dependency-light and AOT/trim-ready. We don't enable PublishAot yet
         (the .NET tool packaging model produces a framework-dependent apphost), but we keep the code
         AOT/trim-clean via the analyzers so flipping it on later is mechanical. -->
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>

    <!-- .NET Tool configuration. The thin client is the dotnet-tool entry point that discovers/launches
         (or, in non-daemon mode, directly hosts) and relays to the bundled language server. It replaces
         Microsoft.CodeAnalysis.LanguageServer as the tool entry point while keeping the same package id. -->
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <PackageId>roslyn-language-server</PackageId>
    <ToolCommandName>roslyn-language-server</ToolCommandName>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Publishing settings. Mirrors the language server so the bundled output lands side-by-side. -->
    <SelfContained>false</SelfContained>
    <PublishDir Condition="'$(RuntimeIdentifier)' != ''">$(ArtifactsDir)/LanguageServer/$(Configuration)/$(TargetFramework)/$(RuntimeIdentifier)</PublishDir>

    <!-- List of runtime identifiers that we want to publish an executable for. -->
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;linux-musl-x64;linux-musl-arm64;osx-x64;osx-arm64</RuntimeIdentifiers>

    <!-- R2R-compile the (tiny) thin client for fast startup when publishing platform-specific executables. -->
    <PublishReadyToRun Condition="'$(Configuration)' == 'Release' AND '$(DotNetBuildUseMonoRuntime)' != 'true'">true</PublishReadyToRun>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup Label="Shared daemon connection files">
    <!-- Source-shared (linked) with Microsoft.CodeAnalysis.LanguageServer so both compute identical
         pipe/mutex names and use the same pipe options. Keep these dependency-light and AOT/trim-safe. -->
    <Compile Include="..\DaemonConnection\*.cs" LinkBase="DaemonConnection" />

    <!-- Share the compiler server's named-pipe helper (and its only dependency) so the thin client and the
         daemon agree on pipe path/options. This thin client has no other copy of these types, so linking
         them here is unambiguous and stays dependency-light (BCL-only, AOT/trim-safe). The language server
         instead reuses the copy already compiled into Microsoft.CodeAnalysis.Workspaces.MSBuild via an alias. -->
    <Compile Include="..\..\Compilers\Shared\NamedPipeUtil.cs" LinkBase="DaemonConnection" />
    <Compile Include="..\..\Compilers\Core\Portable\InternalUtilities\PlatformInformation.cs" LinkBase="DaemonConnection" />
  </ItemGroup>

  <ItemGroup Label="Shared runtime host helper">
    <Compile Include="..\..\Compilers\Shared\RuntimeHostInfo.cs" LinkBase="Shared" />
  </ItemGroup>

  <!--
    Bundle the language server's full published output (apphost, *.dll, *.deps.json, *.runtimeconfig.json,
    native SQLite, RoslynVersion.txt, etc.) into this thin client's publish directory so the thin client can
    launch it side-by-side. Each app keeps its own uniquely-named deps.json/runtimeconfig.json, so merging the
    two publishes into one directory is safe. We deliberately avoid a compile-time ProjectReference to keep the
    thin client free of Roslyn/MEF dependencies and AOT-ready; the server is built and published on demand here.
  -->
  <Target Name="PublishBundledLanguageServer" AfterTargets="Publish">
    <MSBuild Projects="..\Microsoft.CodeAnalysis.LanguageServer\Microsoft.CodeAnalysis.LanguageServer.csproj"
             Targets="Publish"
             Properties="Configuration=$(Configuration);TargetFramework=$(TargetFramework);RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=$(SelfContained);PublishDir=$(PublishDir)" />
  </Target>
</Project>
