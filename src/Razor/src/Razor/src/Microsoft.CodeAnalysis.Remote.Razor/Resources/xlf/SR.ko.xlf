<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2" xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="ko" original="../SR.resx">
    <body>
      <trans-unit id="0_is_not_a_Razor_file_path">
        <source>'{0}' is not a Razor file path.</source>
        <target state="translated">'{0}’은(는) Razor 파일 경로가 아닙니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="AddTagHelper_directive_is_unnecessary">
        <source>@addTagHelper directive is unnecessary.</source>
        <target state="translated">@addTagHelper 지시문은 필요하지 않습니다.</target>
        <note>@addTagHelper is a keyword</note>
      </trans-unit>
      <trans-unit id="Couldnt_get_a_source_generator_run_result">
        <source>Couldn't get a source generator run result for project '{0}'.</source>
        <target state="translated">프로젝트 '{0}'에 대한 원본 생성기 실행 결과를 가져올 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Couldnt_get_the_source_generated_document_for_hint_name">
        <source>Couldn't get the source generated document for hint name '{0}' that we got from the generator run result.</source>
        <target state="translated">생성기 실행 결과에서 얻은 힌트 이름 '{0}'에 대한 원본 생성 문서를 가져올 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Create_Component_FromTag_Title">
        <source>Create component from tag</source>
        <target state="translated">태그에서 구성 요소 만들기</target>
        <note />
      </trans-unit>
      <trans-unit id="Document_does_not_belong_to_this_project">
        <source>Document does not belong to this project.</source>
        <target state="translated">문서가 이 프로젝트에 속하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Document_is_not_a_Razor_document">
        <source>Document is not a Razor document.</source>
        <target state="translated">문서가 Razor 문서가 아닙니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ExtractTo_CodeBehind_Title">
        <source>Extract block to code behind</source>
        <target state="translated">코드 숨김에 블록 추출</target>
        <note />
      </trans-unit>
      <trans-unit id="ExtractTo_Component_Title">
        <source>Extract element to new component</source>
        <target state="translated">새 구성 요소에 요소 추출</target>
        <note />
      </trans-unit>
      <trans-unit id="ExtractTo_Css_Title">
        <source>Extract to {0}.css</source>
        <target state="translated">{0}.css로 추출</target>
        <note />
      </trans-unit>
      <trans-unit id="Generate_Async_Event_Handler_Title">
        <source>Generate Async Event Handler '{0}'</source>
        <target state="translated">비동기 이벤트 처리기 '{0}' 생성</target>
        <note />
      </trans-unit>
      <trans-unit id="Generate_Event_Handler_Title">
        <source>Generate Event Handler '{0}'</source>
        <target state="translated">이벤트 처리기 '{0}' 생성</target>
        <note />
      </trans-unit>
      <trans-unit id="Generator_run_result_did_not_contain_a_code_document">
        <source>Generator run result did not contain a code document for '{0}'.</source>
        <target state="translated">생성기 실행 결과에 '{0}'에 대한 코드 문서가 포함되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Project_does_not_belong_to_this_solution">
        <source>Project does not belong to this solution.</source>
        <target state="translated">프로젝트가 이 솔루션에 속하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Project_does_not_contain_any_Razor_documents">
        <source>Project does not contain any Razor documents.</source>
        <target state="translated">프로젝트에 Razor 문서가 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Promote_using_directive_to">
        <source>Promote using directive to {0}</source>
        <target state="translated">using 지시문을 {0} 수준 올리기</target>
        <note />
      </trans-unit>
      <trans-unit id="Razor_source_generator_did_not_produce_a_host_output">
        <source>Razor source generator did not produce a host output for project '{0}': {1}</source>
        <target state="translated">Razor 원본 생성기가 프로젝트 '{0}'에 대한 호스트 출력을 생성하지 않았습니다. {1}</target>
        <note />
      </trans-unit>
      <trans-unit id="Razor_source_generator_host_output_is_not_RazorGeneratorResult">
        <source>Razor source generator host output is not of type RazorGeneratorResult for project '{0}': {1}</source>
        <target state="translated">Razor 원본 생성기 호스트 출력이 프로젝트 '{0}'에 대한 RazorGeneratorResult 형식이 아닙니다. {1}</target>
        <note />
      </trans-unit>
      <trans-unit id="Razor_source_generator_is_not_referenced">
        <source>Razor source generator is not referenced or no run result found for project '{0}'.</source>
        <target state="translated">Razor 원본 생성기가 참조되지 않았거나 프로젝트 '{0}'에 대한 실행 결과를 찾을 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Razor_source_generator_reference_incorrect">
        <source>Razor source generator is referenced from '{0}' but we are expecting '{1}', for project '{2}'.</source>
        <target state="translated">Razor 원본 생성기는 '{0}'에서 참조되지만, 프로젝트 '{2}'의 경우 '{1}'이(가) 필요합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Remove_unnecessary_directives">
        <source>Remove unnecessary directives</source>
        <target state="translated">불필요한 지시문 제거</target>
        <note />
      </trans-unit>
      <trans-unit id="Simplify_Fully_Qualified_Component_Title">
        <source>Simplify fully qualified component</source>
        <target state="translated">정규화된 구성 요소 간소화</target>
        <note />
      </trans-unit>
      <trans-unit id="Simplify_Tag_To_SelfClosing_Title">
        <source>Simplify tag to self-closing</source>
        <target state="translated">태그를 자체 닫음으로 간소화</target>
        <note />
      </trans-unit>
      <trans-unit id="Sort_And_Consolidate_Usings_Title">
        <source>Sort and consolidate usings</source>
        <target state="translated">using 정렬 및 통합</target>
        <note />
      </trans-unit>
      <trans-unit id="Unknown_RazorMetaCode">
        <source>Attempted to visit a RazorMetaCode other than '{' or '}'.</source>
        <target state="translated">''{' or '}' 이외의 RazorMetaCode를 방문하려고 했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="Unsupported_type_0">
        <source>Unsupported type: '{0}'.</source>
        <target state="translated">지원되지 않는 유형: '{0}'.</target>
        <note />
      </trans-unit>
      <trans-unit id="Wrap_attributes">
        <source>Wrap attributes</source>
        <target state="translated">특성을 래핑합니다.</target>
        <note />
      </trans-unit>
    </body>
