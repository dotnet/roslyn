# Spanner Graph Search - Environment Configuration
# Copy this file to env.config and edit the values to match your Google Cloud Spanner setup.
# This file is loaded by the spanner-graph-search skill scripts.

SPANNER_PROJECT_ID=your-gcp-project-id
SPANNER_INSTANCE_ID=your-spanner-instance
SPANNER_DATABASE_ID=your-database
SPANNER_GRAPH_NAME=YourGraphName
SPANNER_EMBEDDING_MODEL_NAME=gemini-embedding-001
SPANNER_LLM_MODEL_NAME=gemini-2.5-pro
SPANNER_VERTEXAI_LOCATION=europe-west4
SPANNER_SEARCH_TOP_K=5
