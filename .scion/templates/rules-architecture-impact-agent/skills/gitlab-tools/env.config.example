# GitLab Tools - Environment Configuration
# Edit these values to match your GitLab setup.
# This file is read by the agent (not by a script) to construct glab commands.

# GitLab host (without protocol). Used for --hostname flag.
GITLAB_HOST=

# Default project path (namespace/project).
# Used when --repo is not explicitly provided.
GITLAB_PROJECT=

# Authentication:
# The glab CLI handles auth via `glab auth login`.
# Alternatively, set GITLAB_TOKEN as an environment variable.
# Do NOT store tokens in this file — use `glab auth login` or env vars.
